{
  "name": "cloudcode",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "daytona:snapshot": "node scripts/create-daytona-cloudcode-snapshot.mjs",
    "start": "next start",
    "trigger:dev": "trigger dev",
    "trigger:deploy": "trigger deploy",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "lint:eslint": "eslint",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "format:prettier": "prettier --write \"**/*.{ts,tsx}\"",
    "check:codex-app-server-protocol": "tsx scripts/check-codex-app-server-protocol.ts",
    "smoke:codex-app-server": "tsx scripts/smoke-codex-app-server.ts",
    "test:codex-app-server": "tsx scripts/test-codex-app-server.ts && tsx scripts/test-codex-app-server-daemon.ts && pnpm check:codex-app-server-protocol",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@clerk/nextjs": "^7.3.0",
    "@daytona/sdk": "0.172.0",
    "@novnc/novnc": "^1.7.0",
    "@pierre/diffs": "^1.1.20",
    "@pierre/trees": "1.0.0-beta.3",
    "@trigger.dev/sdk": "^4.4.6",
    "@xterm/addon-fit": "0.11.0",
    "@xterm/xterm": "6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.37.0",
    "geist": "^1.7.0",
    "lucide-react": "^1.14.0",
    "next": "16.1.7",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.6.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "unicode-animations": "^1.0.3",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@next/env": "^16.1.7",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.1.7",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "postcss": "^8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "react-doctor": "^0.4.0",
    "tailwindcss": "^4.2.1",
    "trigger.dev": "^4.4.6",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  }
