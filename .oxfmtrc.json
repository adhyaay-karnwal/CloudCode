{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "endOfLine": "lf",
  "semi": false,
  "singleQuote": false,
  "tabWidth": 2,
  "trailingComma": "es5",
  "printWidth": 80,
  "sortTailwindcss": {
    "stylesheet": "app/globals.css",
    "functions": ["cn", "cva"]
  },
  "sortPackageJson": false,
  "ignorePatterns": [
    "dist/",
    "node_modules/",
    ".next/",
    ".turbo/",
    "coverage/",
    ".trigger/",
    ".playwright-cli/",
    "out/",
    "build/",
    "convex/_generated/",
    "next-env.d.ts",
    "pnpm-lock.yaml",
    ".pnpm-store/"
  ]
}
